APP_NAME=satellite-analysis-poc
APP_VERSION=0.1.0
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOADS_DIR=uploads
RESULTS_DIR=results
DATABASE_URL=postgresql://satellite:satellite@localhost:5433/satellite
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_UPLOADS_BUCKET=satellite-uploads
MINIO_RESULTS_BUCKET=satellite-results
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
MODEL_BACKEND=grounded_sam
MODEL_CACHE_DIR=models/cache
OBJECT_CACHE_DIR=storage/cache
GROUNDING_DINO_MODEL_ID=IDEA-Research/grounding-dino-tiny
SAM_MODEL_ID=facebook/sam-vit-base
MODEL_BOX_THRESHOLD=0.18
MODEL_TEXT_THRESHOLD=0.18
MODEL_USE_TILING=true
MODEL_TILE_SIZE=768
MODEL_TILE_OVERLAP=0.2
MAX_UPLOAD_MB=25
